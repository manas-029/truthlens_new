DEBUG=True
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Local default:
DATABASE_URL=sqlite:///db.sqlite3
# Docker/Postgres:
# DATABASE_URL=postgres://truthlens:truthlens@db:5432/truthlens

REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# False uses deterministic forensic feature checks. True uses demo-only seeded mock scores.
USE_MOCK_INFERENCE=False

MAX_UPLOAD_SIZE_MB=200
MEDIA_ROOT=media
MEDIA_RETENTION_DAYS=30
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=TruthLens <noreply@truthlens.local>
